# ─────────────────────────────────────────────────────────────────
# Big Cloud Metrics AI — Environment Variables
# Copy this file to .env.local and fill in all values
# ─────────────────────────────────────────────────────────────────

# DATABASE (Neon.tech - get from https://neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NEXTAUTH (generate secret with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-super-secret-key-here-change-this"
NEXTAUTH_URL="http://localhost:3000"

# EMAIL (Resend - get from https://resend.com)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Big Cloud Metrics <noreply@yourdomain.com>"

# APP
NEXT_PUBLIC_APP_NAME="Big Cloud Metrics AI"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# SUPER ADMIN SEED (used only during initial db:seed)
SEED_ADMIN_NAME="George Michael"
SEED_ADMIN_EMAIL="george@pillcloudpharmacy.com"
SEED_ADMIN_PASSWORD="Admin2026!"
